{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raiatea.dev/schema/learner-evidence-export-v1.schema.json",
  "title": "Raiatea Learner Evidence Export v1",
  "type": "object",
  "required": ["format", "version", "module", "progress"],
  "properties": {
    "format": {"const": "raiatea-learner-evidence"},
    "version": {"const": 1},
    "module": {
      "type": "object",
      "required": ["id", "title", "language", "stepCount"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "title": {"type": "string", "minLength": 1},
        "language": {"type": "string", "minLength": 1},
        "stepCount": {"type": "integer", "minimum": 1},
        "source": {
          "type": "object",
          "properties": {
            "title": {"type": "string", "minLength": 1},
            "chapter": {"type": "string", "minLength": 1},
            "section": {"type": "string", "minLength": 1},
            "figure": {"type": "string", "minLength": 1},
            "pages": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "integer", "minimum": 1}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "progress": {
      "type": "object",
      "required": ["currentStep", "steps"],
      "properties": {
        "currentStep": {"type": "integer", "minimum": 0},
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["index", "title", "attempts", "correct", "usedRemediation", "activityCompleted"],
            "properties": {
              "index": {"type": "integer", "minimum": 0},
              "title": {"type": "string", "minLength": 1},
              "attempts": {"type": "integer", "minimum": 0},
              "correct": {"type": "boolean"},
              "usedRemediation": {"type": "boolean"},
              "activityCompleted": {"type": "boolean"}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
