{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raiatea.dev/schema/learner-evidence-migration-manifest-v1.schema.json",
  "title": "Raiatea Learner Evidence Migration Manifest v1",
  "type": "object",
  "required": ["format", "version", "source", "target", "operations"],
  "properties": {
    "format": {"const": "raiatea-learner-evidence-migration"},
    "version": {"const": 1},
    "source": {"$ref": "#/$defs/endpoint"},
    "target": {"$ref": "#/$defs/endpoint"},
    "operations": {
      "type": "object",
      "required": ["preserve", "retire", "introduce"],
      "properties": {
        "preserve": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "required": ["sourceStepId", "targetStepId"],
            "properties": {
              "sourceStepId": {"$ref": "#/$defs/stableId"},
              "targetStepId": {"$ref": "#/$defs/stableId"}
            },
            "additionalProperties": false
          }
        },
        "retire": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stableId"}
        },
        "introduce": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stableId"}
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "endpoint": {
      "type": "object",
      "required": ["moduleId", "revision", "stepIds"],
      "properties": {
        "moduleId": {"$ref": "#/$defs/stableId"},
        "revision": {"type": "integer", "minimum": 1},
        "stepIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/stableId"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
